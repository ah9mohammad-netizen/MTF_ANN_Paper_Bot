# ========================================================
# XAU-USDT Gold Edge v3 — Paper Trading & Telegram
# ========================================================

ENV=production
PAPER_TRADING=true
PAPER_BALANCE=100.00

SYMBOL=XAU-USDT
EXCHANGE_ID=bybit
TIMEFRAME=5m
POLL_INTERVAL_SECONDS=5.0

# Book risk
MAX_LEVERAGE=50
RISK_PER_TRADE_PCT=1.5
MAX_SPREAD_USD=0.40
MAX_OPEN_TRADES=1
MAX_DAILY_LOSS_PCT=5.0
MAX_TRADES_PER_DAY=3
ENTRY_COOLDOWN_SECONDS=300
MARGIN_CAP_PCT=40.0

# Sessions UTC (London + NY overlap). Format: start-end,start-end
ALLOWED_SESSIONS=7-10,12-16
ASIAN_START_HOUR_UTC=0
ASIAN_END_HOUR_UTC=7
NY_ORB_START_HOUR_UTC=13
NY_ORB_END_HOUR_UTC=16
NY_ORB_DECISION_HOUR_UTC=16

# Indicators / regime
EMA_TREND_PERIOD=200
EMA_FAST_PERIOD=50
ATR_PERIOD=14
RSI_PERIOD=14
RSI_OVERBOUGHT=72.0
RSI_OVERSOLD=28.0
ADX_PERIOD=14
ADX_RANGE_MAX=22.0
ADX_TREND_MIN=25.0
MIN_DI_SPREAD=5.0

# Structure
SWEEP_MIN_PIERCE_USD=0.30
MIN_ASIAN_RANGE_USD=3.00
MAX_ASIAN_RANGE_USD=45.00
ENABLE_SWEEP_FADE=true
ENABLE_ASIA_BREAKOUT=true
ENABLE_NY_ORB=true
REQUIRE_TURN_CONFIRM=true
REQUIRE_CLOSE_BEYOND=true

# Cost gate
ROUND_TRIP_COST_USD=0.35
MIN_SL_COST_MULTIPLE=4.0
MIN_TP_COST_MULTIPLE=6.0
MIN_ATR_USD=0.80

# Exits — BE then trail; full close at runner TP (no early partial)
SL_ATR_MULTIPLIER=1.5
MIN_SL_USD=1.20
BE_TRIGGER_RR=1.0
TRAIL_ATR_MULTIPLIER=1.5
TP_RR_RATIO=4.0

# Railway Volume
DB_PATH=/data/history.db
DATABASE_URL=sqlite:////data/history.db

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

APEX_API_KEY=
APEX_API_SECRET=
APEX_PASSPHRASE=
