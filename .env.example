# ========================================================
# XAU-USDT Quantitative Paper Trading & Telegram UI Config
# ========================================================

# Deployment Environment
ENV=production
PAPER_TRADING=true
PAPER_BALANCE=100.00

# Target Asset & Exchange
SYMBOL=XAU-USDT
EXCHANGE_ID=bybit
TIMEFRAME=5m
POLL_INTERVAL_SECONDS=5.0

# Leverage & Risk Settings ($100 Starting Capital)
MAX_LEVERAGE=50
RISK_PER_TRADE_PCT=1.5
MAX_SPREAD_USD=0.45

# Database URL / Volume Storage Path (`/data/History.db` on Railway Volume)
# When you create a Volume in Railway mounted at `/data`, the bot automatically saves inside `/data/History.db`
DB_PATH=/data/History.db
DATABASE_URL=sqlite:////data/History.db

# Telegram Bot API Credentials (UI & Alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Apex / Live Exchange API Keys (For later phase after paper verification)
APEX_API_KEY=
APEX_API_SECRET=
APEX_PASSPHRASE=
